        "jsCode": "// Get current item data\nconst data = $input.item.json;\n\n// Pull previous count if it exists\nlet count = data.publish_count || 0;\n\n// Check if this execution represents a successful publish\nif (\n  data.status === \"published\" ||\n  data.result === \"success\" ||\n  data.posted === true\n) {\n  count += 1;\n}\n\n// Return updated count\nreturn {\n  json: {\n    ...data,\n    publish_count: count,\n    last_published_at: new Date().toISOString()\n  }\n};"
      },
