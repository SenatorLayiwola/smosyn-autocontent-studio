        "jsCode": "const item = $input.item.json;\n\nconst postText = item['Post Text'] || '';\nconst hashtagsRaw = item.Hashtags || '';\n\n// Parse hashtags (handles both JSON array string and plain text)\nlet hashtags = '';\n\nif (hashtagsRaw) {\n  try {\n    // Try parsing as JSON array\n    const hashtagArray = JSON.parse(hashtagsRaw);\n    hashtags = hashtagArray.join(' ');\n  } catch (e) {\n    // Already plain text, use as-is\n    hashtags = hashtagsRaw;\n  }\n}\n\n// Combine post text with hashtags\nconst finalPost = hashtags \n  ? `${postText}\\n\\n${hashtags}` \n  : postText;\n\nreturn {\n  json: {\n    ...item,\n    FINAL_POST: finalPost,\n    HAS_IMAGE: item['Image URL'] ? true : false\n  }\n};\n\n"
      },
