    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet message = 'Weekly Content Calendar\\n\\n';\n\nconst byDate = {};\nitems.forEach(item => {\n  const date = item.json.scheduled_date;\n  if (!byDate[date]) byDate[date] = [];\n  byDate[date].push(item.json);\n});\n\nObject.keys(byDate).sort().forEach(date => {\n  message += `${date}\\n`;\n  byDate[date].forEach(post => {\n    message += `- ${post.scheduled_time} ${post.PLATFORM}: ${post.TOPIC}\\n`;\n  });\n  message += '\\n';\n});\n\nreturn { json: { preview: message } };"
      },
