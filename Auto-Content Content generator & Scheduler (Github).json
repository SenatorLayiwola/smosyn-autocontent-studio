    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Group by platform\nconst byPlatform = {};\nitems.forEach(item => {\n  const platform = item.json.PLATFORM;\n  if (!byPlatform[platform]) byPlatform[platform] = [];\n  byPlatform[platform].push(item.json);\n});\n\n// Schedule 3 posts/day per platform\nconst schedule = [];\nconst startDate = new Date();\nstartDate.setDate(startDate.getDate() + 1); // Start tomorrow\n\nObject.keys(byPlatform).forEach(platform => {\n  const posts = byPlatform[platform];\n  \n  posts.slice(0, 21).forEach((post, idx) => {\n    const dayOffset = Math.floor(idx / 3);\n    const postDate = new Date(startDate);\n    postDate.setDate(postDate.getDate() + dayOffset);\n    \n    // Times: 10 AM, 2 PM, 6 PM\n    const times = ['10:00', '14:00', '18:00'];\n    const time = times[idx % 3];\n    \n    schedule.push({\n      ...post,\n      scheduled_date: postDate.toISOString().split('T')[0],\n      scheduled_time: time\n    });\n  });\n});\n\nreturn schedule.map(item => ({ json: item }));"
      },
      "type": "n8n-nodes-base.code",
